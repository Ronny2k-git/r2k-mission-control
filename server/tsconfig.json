{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "../",
    "outDir": "./dist",

    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@common/*": ["../common/*"]
    },

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },

  "include": ["src/**/*.ts", "../common/**/*.ts"],

  "exclude": ["node_modules", "dist", "generated"]
}
