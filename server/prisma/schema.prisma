generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MissionType {
  exploration
  research
  cargo
  crewed
}

enum Customer {
  NASA
  ESA
  JAXA
  CSA
  SpaceX
  BlueOrigin @map("Blue Origin")
  DARPA
  Axiom
}


model Mission {
  id           Int  @ id @default(autoincrement())
  name         String
  rocket       String
  target       String
  type         MissionType
  startDate    DateTime
  endDate      DateTime
  description  String?
  customers    Json
  isAborted    Boolean  @default(false)
  createdAt    DateTime @default(now())
}